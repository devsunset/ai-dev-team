# =============================================================================
# [CORE PATHS]
# 이 작업 공간은 명시된 폴더 안에서만 결과를 기록합니다.
WORKSPACE_DIR=workspace
LOG_DIR=logs
VISUAL_CENTER=workspace/visual_center.html

# =============================================================================
# [PROJECT]
# 원하는 목표를 적어주세요. CLI --goal 값이 존재하면 그 값이 우선합니다.
PROJECT_GOAL=풀스택 AI 개발팀이 PRD/TRD 기반으로 결과물을 자동 작성/검증하는 워크플로우
FRAMEWORK=crewai  # 변경 가능: crewi, autogen, langgraph, pydanticai, agno, smolagents, metagpt, chatdev, agency-swarm, plandex
### framework 설명
### crewai: 역할 기반 협업 로직
### autogen: 에이전트 토론+실행 루프
### langgraph: 그래프 제어 워크플로우
### pydanticai: 데이터/타입 안정성 강조
### agno: 실시간 웹/지식 통합
### smolagents: 로컬 모델(예: Ollama) 중심
### metagpt: 문서/설계 자동 생성
### chatdev: 가상 회사처럼 빠른 결과물
### agency-swarm: 계층 조직 시뮬레이션
### plandex: 큰 코드베이스 리팩토링

# =============================================================================
# [TERMINAL MODE]
# TERMINAL_MODE를 비워두면 macOS에서는 cmux, Windows/Linux에서는 tmux로 자동 결정됩니다.
# 명시적으로 tmux/cmux를 넣으면 그 모드로 강제합니다. (CMUX는 맥OS만 유효합니다.)
TERMINAL_MODE=

# =============================================================================
# [ENVIRONMENT & MODE HINTS]
# CMUX_PORT는 cmux 브라우저가 열릴 로컬 포트입니다. tmux는 포트를 사용하지 않으며 로그 중심입니다.
CMUX_PORT=8000
LOG_LEVEL=INFO

# =============================================================================
# [AGENT & ROLE]
# 쉼표로 나열한 순서대로 에이전트를 기동합니다. 원하는 역할을 더 추가해도 됩니다.
# AGENT_TEAM=pm,architect,backend,frontend,designer,data,qa,devops,security
AGENT_TEAM=pm,architect,backend,frontend,qa

# =============================================================================
# [LLM ROUTING]
# PM_VENDOR=openai
# PM_MODEL=gpt-4o
# DEV_VENDOR=groq
# DEV_MODEL=llama3-70b-8192
# QA_VENDOR=gemini
# QA_MODEL=gemini-1.5-flash

PM_VENDOR=gemini
PM_MODEL=gemini-1.5-flash
DEV_VENDOR=groq
DEV_MODEL=llama3-70b-8192
QA_VENDOR=gemini
QA_MODEL=gemini-1.5-flash

# =============================================================================
# [API KEYS]
# 각 키를 채워 넣으면 main.py에서 해당 벤더를 실제로 '연결'하려 시도합니다. 빈 값은 무시됩니다.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# =============================================================================
# [OPERATIONAL GUARDS]
# TOKEN_BUDGET은 전체 실행에서 사용할 토큰 예산(단위: 토큰)
# HEALING_ATTEMPTS는 각 에이전트가 self-healing 루프를 돌 수 있는 최대 반복 횟수입니다.
TOKEN_BUDGET=200000
HEALING_ATTEMPTS=4

# =============================================================================
# [OPTIONAL FLAGS]
# DEBUG=true로 설정하면 console logging이 DEBUG 레벨로 바뀝니다.
DEBUG=false
# =============================================================================
